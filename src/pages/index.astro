---
import "../styles/global.css";

const shows = [
  {
    title: "风中摇曳的洋紫荆",
    desc: "加拿大话剧团出品",
    url: "/canadiandramaticarts",
    poster: "/events/yangzijing.png"
  }
];
---

<html lang="zh">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>近期演出</title>
</head>

<body class="min-h-screen bg-zinc-50 text-zinc-900">

<main class="mx-auto max-w-6xl px-6 py-16">

<h1 class="text-3xl font-bold mb-10">近期演出</h1>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

{shows.map(show => (

<a
href={show.url}
class="group rounded-2xl border border-zinc-200 bg-white shadow-sm hover:shadow-lg transition overflow-hidden"
>

<!-- Poster container -->
<div class="aspect-[9/16] bg-black flex items-center justify-center">

<img
src={show.poster}
alt={show.title}
class="h-full w-full object-contain transition group-hover:scale-105"
/>

</div>

<!-- Card text -->
<div class="p-6">

<div class="text-xl font-semibold">
{show.title}
</div>

<div class="mt-2 text-zinc-600 text-sm">
{show.desc}
</div>

<div class="mt-4 text-sm font-medium text-zinc-900">
购票 →
</div>

</div>

</a>

))}

</div>

</main>

</body>
</html>
