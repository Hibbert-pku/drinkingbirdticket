---
const url = new URL(Astro.request.url);
const order = url.searchParams.get("order") ?? "ORDER-UNKNOWN";
const name = url.searchParams.get("name") ?? "";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Order received</title>
  </head>
  <body class="min-h-screen bg-white text-zinc-900">
    <main class="mx-auto max-w-2xl px-4 py-12 space-y-4">
      <h1 class="text-2xl font-semibold">Order received ✅</h1>
      <p>Your order ID:</p>
      <div class="rounded border p-4 font-mono">{order}</div>
      <p class="text-zinc-600">
        Please include <b>{order}{name ? `-${name}` : ""}</b> in your payment note so we can match it quickly.
      </p>
      <a class="inline-block rounded border px-4 py-2" href="/">Back</a>
    </main>
  </body>
</html>
