---
import "../../styles/global.css";

const event = {
  title: "心理悬疑大戏《零号嫌疑人》",
  subtitle: "正义之刃，还是深渊之影？",
  badge: "加拿大话剧团出品",
  date: "2026年5月17日（周日） 3:00–5:00 PM",
  venue: "4211 Number 3 Rd, Richmond, BC V6X 1X6",
  poster: "/events/zero.png",
  contact: {
    wechat: "A2321380933",
    email: "ccda5577@gmail.com",
    phone: "778-238-7777",
  },
  tickets: [
    { id: "early", name: "早鸟票", price: 35, note: "5月1日截止" },
    { id: "regular", name: "普通票", price: 43, note: "普通入场" },
    { id: "vip", name: "VIP票", price: 66, note: "优先座位 + 赠饮" },
    { id: "2people", name: "2人团", price: 34, note: "34每人" },
    { id: "3to5people", name: "3-5人团", price: 33, note: "33每人" },
    { id: "5plus", name: "5人以上团", price: 30, note: "30每人" },
  ],
  payment: {
    method: "Interac e-Transfer",
    recipient: "ccda5577@gmail.com",
    noteRule: "付款备注请填写：订单号后四位 + 姓名",
    confirmSla: "我们会在收到付款后 12 小时内人工确认。",
  },
  faq: [
    {
      q: "购票后还需要做什么？",
      a: "购票后请务必添加客服小助手，核对订单信息，避免影响入场。",
    },
    {
      q: "可以预留座位吗？",
      a: "本场演出席位有限，先到先得，不设预留。",
    },
    {
      q: "入场规则是什么？",
      a: "一人一票，凭票入场，逾期作废。",
    },
  ],
};
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{event.title}</title>
    <meta name="description" content={`${event.title} - 购票页面`} />
  </head>

  <body class="min-h-screen bg-zinc-50 text-zinc-900">
    <header class="sticky top-0 z-50 border-b bg-white/85 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
        <div class="font-semibold">{event.title}</div>

        <div class="flex items-center gap-2">
          <a href="/" class="rounded-lg px-3 py-2 text-sm hover:bg-zinc-100">返回首页</a>
          <a href="#intro" class="rounded-lg px-3 py-2 text-sm hover:bg-zinc-100">剧目介绍</a>
          <a href="#highlights" class="rounded-lg px-3 py-2 text-sm hover:bg-zinc-100">剧目亮点</a>
          <a href="#tickets" class="rounded-lg px-3 py-2 text-sm hover:bg-zinc-100">票种</a>
          <a href="#payment" class="rounded-lg px-3 py-2 text-sm hover:bg-zinc-100">付款方式</a>
          <a
            href="#buy"
            class="rounded-lg bg-zinc-900 px-4 py-2 text-sm font-medium text-white hover:bg-zinc-800"
          >
            立即购票
          </a>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-4 py-10">
      <!-- Hero -->
      <section class="grid gap-8 md:grid-cols-2 md:items-start">
        <div class="space-y-4">
          <div class="space-y-3">
            <div class="inline-flex rounded-full bg-zinc-100 px-3 py-1 text-xs font-medium text-zinc-700">
              {event.badge}
            </div>
            <h1 class="text-3xl font-bold tracking-tight md:text-5xl">心理悬疑大戏<br\>《零号嫌疑人》</h1>
            <p class="text-xl font-semibold text-zinc-700">{event.subtitle}</p>
            <p class="text-base text-zinc-600">
              连环凶案、人性博弈、高能反转、心理惊悚天花板，北美期待值拉满，口碑预定，手慢无！
            </p>
          </div>

          <div class="space-y-2 text-zinc-700">
            <div class="flex items-start gap-2">
              <span class="mt-0.5 inline-flex rounded-full bg-zinc-100 px-3 py-1 text-xs font-medium text-zinc-700">
                时间
              </span>
              <span>{event.date}</span>
            </div>
            <div class="flex items-start gap-2">
              <span class="mt-0.5 inline-flex rounded-full bg-zinc-100 px-3 py-1 text-xs font-medium text-zinc-700">
                地点
              </span>
              <span>{event.venue}</span>
            </div>
          </div>

          <div class="flex flex-wrap gap-3 pt-2">
            <a
              href="#buy"
              class="rounded-xl bg-zinc-900 px-5 py-3 text-sm font-medium text-white hover:bg-zinc-800"
            >
              立即购票
            </a>
            <a
              href="#intro"
              class="rounded-xl border border-zinc-200 bg-white px-5 py-3 text-sm font-medium hover:bg-zinc-50"
            >
              查看剧目介绍
            </a>
          </div>

          <div class="rounded-xl border border-zinc-200 bg-white p-4 text-sm text-zinc-600 shadow-sm">
            <div class="font-medium text-zinc-900">购票方式</div>
            提交表单后，请按下方付款方式完成转账。本站采用人工对账确认，不是自动出票系统。
          </div>
        </div>

        <!-- Poster -->
        <div class="overflow-hidden rounded-2xl border border-zinc-200 bg-black shadow-sm">
          <div class="aspect-[9/16] flex items-center justify-center">
            <img
              src={event.poster}
              alt={event.title}
              class="h-full w-full object-contain"
              loading="lazy"
            />
          </div>
        </div>
      </section>

      <!-- Intro -->
      <section
        id="intro"
        class="mt-12 rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm space-y-5 text-zinc-700"
      >
        <h2 class="text-2xl font-semibold text-zinc-900">剧目介绍</h2>

        <p>
          三个月，两起命案，手法利落、现场无痕。
        </p>

        <p>
          死者皆为逃脱法律制裁的“恶人”，却因权势、和解、证据不足逍遥法外。
          神秘凶手以“清道夫”之名，留下字条“罪已认定，审判执行”，以私刑执行“审判”。
        </p>

        <p>
          记者林深，警校出身、敏锐执着，他曝光罪恶，却被舆论推向风口浪尖。
          他有冷静犀利的“搭档”沈策，行踪诡秘的“线人”阿默，务实强硬的刑警老友马会。
          随着第三起袭击发生，所有线索指向同一个方向——凶手，就在他身边。
        </p>

        <p>
          采访、追查、对峙、极限反转。
          家属的痛哭、媒体的狂欢、警方的紧逼、人性的极致拉扯。
        </p>

        <p>
          你以为的正义，可能是暴力；你相信的真相，可能是谎言。
          你同情的受害者，也曾是加害者；你痛恨的凶手，也曾是被伤害的人。
        </p>

        <p>
          舞台之上，没有绝对好人，没有完美反派。
          灯光亮起，是城市的光明与黑暗；幕布拉开，是每个人心底的善与恶。
        </p>

        <p class="font-medium text-zinc-900">
          当审判不再属于法律，当正义沦为私刑，你站在哪一边？
          而最终的零号嫌疑人，究竟是谁？
        </p>
      </section>

      <!-- Highlights -->
      <section
        id="highlights"
        class="mt-12 rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm"
      >
        <h2 class="text-2xl font-semibold text-zinc-900">剧目亮点</h2>

        <ul class="mt-5 space-y-4 text-zinc-700">
          <li class="flex gap-3">
            <span class="mt-1 text-zinc-900">•</span>
            <span>高能心理惊悚，全程反转不停，结局颠覆认知</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-1 text-zinc-900">•</span>
            <span>沉浸式舞台设计，打破第四面墙，与观众零距离互动</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-1 text-zinc-900">•</span>
            <span>深度人性拷问：直面正义、法律、舆论、私刑的模糊边界</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-1 text-zinc-900">•</span>
            <span>实力派演员演绎多重人格与极致心理博弈</span>
          </li>
        </ul>
      </section>

      <!-- Audience -->
      <section class="mt-12 rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-semibold text-zinc-900">适合人群</h2>
        <p class="mt-4 text-zinc-700">
          悬疑爱好者、推理剧迷、热衷深度剧情与人性探讨的观众。
        </p>
      </section>

      <!-- Tickets -->
      <section id="tickets" class="mt-12">
        <div class="mb-4 flex items-end justify-between">
          <h2 class="text-2xl font-semibold">开票信息</h2>
          <p class="text-sm text-zinc-600">请选择适合你的票种，再填写下方购票表单。</p>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
          {event.tickets.map((t) => (
            <article class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <div class="text-lg font-semibold">{t.name}</div>
                  <div class="text-sm text-zinc-600">{t.note}</div>
                </div>
                <div class="text-xl font-bold">${t.price}</div>
              </div>

              <div class="mt-4">
                <button
                  class="w-full rounded-xl bg-zinc-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-zinc-800"
                  data-ticket={t.id}
                >
                  选择此票种
                </button>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- Buy -->
      <section id="buy" class="mt-12">
        <div class="mb-4">
          <h2 class="text-2xl font-semibold">填写购票信息</h2>
          <p class="text-sm text-zinc-600">
            提交后会进入成功页面并生成订单号。付款时请把订单号后四位写进备注，方便人工核对。
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          <form
            class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm"
            method="GET"
            action="/canadiandramaticarts/success"
          >
            <div class="grid gap-4">
              <div>
                <label class="mb-1 block text-sm font-medium">姓名</label>
                <input
                  class="w-full rounded-xl border border-zinc-200 bg-white px-3 py-2.5 text-sm outline-none focus:ring-2 focus:ring-zinc-900/20"
                  name="name"
                  required
                />
              </div>

              <div>
                <label class="mb-1 block text-sm font-medium">邮箱</label>
                <input
                  class="w-full rounded-xl border border-zinc-200 bg-white px-3 py-2.5 text-sm outline-none focus:ring-2 focus:ring-zinc-900/20"
                  type="email"
                  name="email"
                  required
                />
              </div>

              <div class="grid gap-4 md:grid-cols-2">
                <div>
                  <label class="mb-1 block text-sm font-medium">票种</label>
                  <select
                    id="ticketSelect"
                    class="w-full rounded-xl border border-zinc-200 bg-white px-3 py-2.5 text-sm outline-none focus:ring-2 focus:ring-zinc-900/20"
                    name="ticket"
                    required
                  >
                    {event.tickets.map((t) => (
                      <option value={t.id}>{t.name} (${t.price})</option>
                    ))}
                  </select>
                </div>

                <div>
                  <label class="mb-1 block text-sm font-medium">数量</label>
                  <input
                    class="w-full rounded-xl border border-zinc-200 bg-white px-3 py-2.5 text-sm outline-none focus:ring-2 focus:ring-zinc-900/20"
                    type="number"
                    name="qty"
                    min="1"
                    max="10"
                    value="1"
                    required
                  />
                </div>
              </div>

              <div>
                <label class="mb-1 block text-sm font-medium">备注（可选）</label>
                <textarea
                  class="w-full rounded-xl border border-zinc-200 bg-white px-3 py-2.5 text-sm outline-none focus:ring-2 focus:ring-zinc-900/20"
                  name="notes"
                  rows="4"
                  placeholder="例如：同行人姓名、特殊需求等"
                ></textarea>
              </div>

              <button
                class="rounded-xl bg-zinc-900 px-5 py-3 text-sm font-medium text-white hover:bg-zinc-800"
                type="submit"
              >
                提交订单
              </button>

              <div class="text-xs text-zinc-500">
                提交后请前往成功页面查看订单号，并按要求完成付款备注。
              </div>
            </div>
          </form>

          <!-- Payment -->
          <aside
            id="payment"
            class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm"
          >
            <h3 class="text-lg font-semibold">购票须知</h3>

            <div class="mt-4 space-y-3 text-sm text-zinc-700">
              <div>✅ 购票后请务必添加客服小助手核对订单信息</div>
              <div>✅ 本场演出席位有限，先到先得，不设预留</div>
              <div>✅ 一人一票，凭票入场，逾期作废</div>
            </div>

            <div class="mt-6 border-t border-zinc-200 pt-6">
              <h4 class="text-base font-semibold">付款方式</h4>

              <div class="mt-3 space-y-3 text-sm text-zinc-700">
                <div class="flex justify-between gap-3">
                  <span class="text-zinc-500">方式</span>
                  <span class="font-medium">{event.payment.method}</span>
                </div>

                <div class="flex justify-between gap-3">
                  <span class="text-zinc-500">收款人</span>
                  <span class="font-medium">{event.payment.recipient}</span>
                </div>

                <div class="rounded-xl bg-zinc-50 p-3">
                  <div class="text-zinc-500">付款备注</div>
                  <div class="mt-1 font-mono text-xs md:text-sm">{event.payment.noteRule}</div>
                </div>

                <div class="text-zinc-600">{event.payment.confirmSla}</div>
              </div>

              <div class="mt-5 rounded-xl border border-zinc-200 bg-white p-4 text-sm">
                <div class="font-medium">联系方式</div>
                <div class="mt-2 space-y-1 text-zinc-600">
                  <div>微信：<b>{event.contact.wechat}</b></div>
                  <div>邮箱：<b>{event.contact.email}</b></div>
                  <div>
                    电话：
                    <a href={`tel:${event.contact.phone}`} class="font-semibold text-zinc-900">
                      {event.contact.phone}
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </aside>
        </div>
      </section>

      <!-- Closing line -->
      <section class="mt-12 rounded-2xl border border-zinc-200 bg-zinc-900 p-6 text-white shadow-sm">
        <div class="text-xl font-semibold">正义？私刑？英雄？恶魔？</div>
        <div class="mt-2 text-zinc-300">剧场见，揭晓终极真相！</div>
      </section>

      <!-- FAQ -->
      <section class="mt-12">
        <h2 class="text-2xl font-semibold">常见问题</h2>
        <div class="mt-4 grid gap-4 md:grid-cols-2">
          {event.faq.map((item) => (
            <div class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
              <div class="font-semibold">{item.q}</div>
              <div class="mt-2 text-sm text-zinc-600">{item.a}</div>
            </div>
          ))}
        </div>
      </section>

      <footer class="mt-12 border-t border-zinc-200 py-8 text-sm text-zinc-600">
        © {new Date().getFullYear()} 加拿大话剧团
      </footer>
    </main>

    <script>
      (() => {
        const select = document.getElementById("ticketSelect");
        const buttons = document.querySelectorAll("button[data-ticket]");
        buttons.forEach((btn) => {
          btn.addEventListener("click", () => {
            const id = btn.getAttribute("data-ticket");
            if (select && id) select.value = id;
            document.getElementById("buy")?.scrollIntoView({ behavior: "smooth" });
          });
        });
      })();
    </script>
  </body>
</html>
